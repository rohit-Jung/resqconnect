---
config:
  layout: elk
---
erDiagram
    USER {
        uuid id PK
        string name
        integer age
        bigint phone_number UK
        string email UK
        string primary_address
        string password
        boolean is_verified
        enum role "user/admin"
        string profile_picture
        string verification_token
        timestamp token_expiry
        geometry location
        bigint h3_index
        json current_location
        string reset_password_token
        timestamp reset_password_token_expiry
        boolean notify_emergency_contacts
        string emergency_notification_method
        timestamp created_at
        timestamp updated_at
        text push_token
    }

    ORGANIZATION {
        uuid id PK
        string name UK
        string email UK
        enum service_category
        bigint general_number
        string password
        boolean is_verified
        enum org_status "not_active/active/not_verified"
        enum lifecycle_status "pending_approval/active/suspended/trial_expired"
        string verification_token
        timestamp token_expiry
        string reset_password_token
        timestamp reset_password_token_expiry
        timestamp created_at
        timestamp updated_at
    }

    SERVICE_PROVIDER {
        uuid id PK
        string name
        integer age
        string email UK
        bigint phone_number UK
        string primary_address
        string service_area
        string password
        enum service_type
        boolean is_verified
        string profile_picture
        geometry last_location
        bigint h3_index
        json current_location
        json vehicle_information
        uuid organization_id FK
        enum service_status "available/assigned/off_duty"
        string verification_token
        timestamp token_expiry
        string reset_password_token
        timestamp reset_password_token_expiry
        string pan_card_url
        string citizenship_url
        enum document_status "not_submitted/pending/approved/rejected"
        text rejection_reason
        timestamp verified_at
        uuid verified_by FK
        timestamp status_updated_at
        timestamp created_at
        timestamp updated_at
    }

    EMERGENCY_REQUEST {
        uuid id PK
        uuid user_id FK
        enum service_type
        enum request_status "pending/accepted/assigned/rejected/in_progress/completed/cancelled/no_providers_available"
        string description
        integer request_timeout
        json location
        geometry geo_location
        bigint h3_index
        integer search_radius
        timestamp must_connect_by
        timestamp provider_connected_at
        timestamp expires_at
        timestamp created_at
        timestamp updated_at
    }

    EMERGENCY_RESPONSE {
        uuid id PK
        uuid emergency_request_id FK
        uuid service_provider_id FK
        enum status_update "accepted/arrived/on_route/rejected"
        json origin_location
        json destination_location
        timestamp assigned_at
        timestamp responded_at
        string update_description
        timestamp created_at
        timestamp updated_at
    }

    EMERGENCY_CONTACT {
        uuid id PK
        string name
        boolean is_comman_contact
        string relationship
        string phone_number
        string email
        uuid user_id FK
        boolean notify_on_emergency
        string notification_method
        text push_token
        timestamp created_at
        timestamp updated_at
    }

    FEEDBACK {
        uuid id PK
        uuid user_id FK
        uuid service_provider_id FK
        string message
        integer service_ratings
        timestamp created_at
        timestamp updated_at
    }

    NOTIFICATION {
        uuid id PK
        uuid user_id FK
        uuid service_provider_id FK
        string message
        string type
        enum priority "low/medium/high"
        string source
        json metadata
        string delivery_status
        boolean is_read
        boolean do_not_disturb
        timestamp created_at
        timestamp updated_at
    }

    REQUEST_EVENTS {
        uuid id PK
        uuid request_id FK
        string event_type
        uuid provider_id FK
        json metadata
        timestamp timestamp
    }

    OUTBOX {
        uuid id PK
        uuid aggregate_id
        string aggregate_type
        string event_type
        enum kafka_topic "fire_events/medical_events/rescue_events/police_events"
        text payload
        enum outbox_status "pending/published/failed"
        integer retry_count
        timestamp last_retry_at
        timestamp published_at
        timestamp created_at
    }

    AUDIT_LOG {
        uuid id PK
        enum actor_type "user/service_provider/organization/admin/internal/anonymous"
        uuid actor_id
        string method
        text path
        string status_code
        string ip
        text user_agent
        uuid organization_id
        jsonb metadata
        timestamp created_at
    }

    ORGANIZATION_ENTITLEMENTS_SNAPSHOT {
        uuid id PK
        uuid organization_id FK
        integer version
        jsonb entitlements
        timestamp created_at
    }

    SUBSCRIPTION_PLANS {
        uuid id PK
        string name
        integer price
        integer duration_months
        jsonb features
        boolean is_active
        timestamp created_at
        timestamp updated_at
    }

    ORGANIZATION_SUBSCRIPTIONS {
        uuid id PK
        uuid organization_id FK
        uuid plan_id FK
        enum status "active/expired/cancelled"
        timestamp start_date
        timestamp end_date
        timestamp created_at
        timestamp updated_at
    }

    PAYMENTS {
        uuid id PK
        uuid organization_id FK
        uuid subscription_id FK
        integer amount
        string khalti_pidx
        string khalti_transaction_id
        enum status "pending/completed/failed/refunded"
        enum payment_method "khalti/esewa/bank_transfer/cash"
        timestamp created_at
        timestamp completed_at
    }

    CP_ADMIN {
        uuid id PK
        text email UK
        text password_hash
        timestamp created_at
        timestamp updated_at
    }

    CP_ORGANIZATION {
        uuid id PK
        text name UK
        enum sector "hospital/police/fire"
        enum status "pending_approval/active/suspended/trial_expired"
        text silo_base_url
        uuid silo_org_id
        timestamp created_at
        timestamp updated_at
    }

    CP_SUBSCRIPTION_PLAN {
        uuid id PK
        text name
        integer price
        integer duration_months
        jsonb features
        boolean is_active
        timestamp created_at
        timestamp updated_at
    }

    CP_ORG_ENTITLEMENTS {
        uuid id PK
        uuid cp_org_id FK
        integer version
        jsonb entitlements
        timestamp created_at
    }

    CP_PAYMENT_INTENT {
        uuid id PK
        uuid cp_org_id FK
        uuid plan_id FK
        text khalti_pidx UK
        text khalti_status
        text khalti_transaction_id
        integer amount
        timestamp created_at
        timestamp updated_at
    }

    CP_ORG_REPLICA {
        uuid id PK
        uuid cp_org_id
        text silo_base_url
        uuid silo_org_id
        jsonb snapshot
        timestamp captured_at
        timestamp created_at
        timestamp updated_at
    }

    CP_SILO_METRICS {
        uuid id PK
        text silo_base_url
        text sector
        jsonb metrics
        timestamp collected_at
        timestamp created_at
    }

    CP_SANITIZED_AUDIT_AGGREGATE {
        uuid id PK
        text silo_base_url
        text sector
        text bucket
        text actor_type
        text status_class
        integer count
        timestamp bucket_start
        timestamp created_at
        timestamp updated_at
    }

    CP_SILO_POLL_CURSOR {
        uuid id PK
        text silo_base_url UK
        timestamp sanitized_index_cursor
        timestamp org_snapshots_cursor
        timestamp last_polled_at
        timestamp created_at
        timestamp updated_at
    }

    USER ||--o{ EMERGENCY_REQUEST : "creates"
    USER ||--o{ EMERGENCY_CONTACT : "has"
    USER ||--o{ FEEDBACK : "writes"
    USER ||--o{ NOTIFICATION : "receives"

    ORGANIZATION ||--o{ SERVICE_PROVIDER : "employs"
    ORGANIZATION ||--o{ SERVICE_PROVIDER : "verifies"
    ORGANIZATION ||--o{ ORGANIZATION_ENTITLEMENTS_SNAPSHOT : "entitlements"
    ORGANIZATION ||--o{ ORGANIZATION_SUBSCRIPTIONS : "subscriptions"
    ORGANIZATION ||--o{ PAYMENTS : "payments"

    SUBSCRIPTION_PLANS ||--o{ ORGANIZATION_SUBSCRIPTIONS : "plans"
    ORGANIZATION_SUBSCRIPTIONS ||--o{ PAYMENTS : "charges"

    SERVICE_PROVIDER ||--o{ EMERGENCY_RESPONSE : "responds"
    SERVICE_PROVIDER ||--o{ FEEDBACK : "receives"
    SERVICE_PROVIDER ||--o{ NOTIFICATION : "receives"
    SERVICE_PROVIDER ||--o{ REQUEST_EVENTS : "events"

    EMERGENCY_REQUEST ||--o{ EMERGENCY_RESPONSE : "responses"
    EMERGENCY_REQUEST ||--o{ REQUEST_EVENTS : "events"

    CP_ORGANIZATION ||--o{ CP_ORG_ENTITLEMENTS : "entitlements"
    CP_ORGANIZATION ||--o{ CP_PAYMENT_INTENT : "payment intents"
    CP_ORGANIZATION ||--o{ CP_ORG_REPLICA : "replicas"
    CP_SUBSCRIPTION_PLAN ||--o{ CP_PAYMENT_INTENT : "plan"
