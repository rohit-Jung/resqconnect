{
  "name": "resq-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "docker": "docker compose -f ./docker/docker-compose.yml up -d ",
    "dev": "bun run docker && bun  --watch ./src/index.ts",
    "format": "bun prettier --write 'src/**/*.{ts,js,json}'",
    "lint": "bun eslint .",
    "lint:fix": "bun eslint ./src/**/.ts --fix",
    "db:migrate": "bun drizzle-kit migrate",
    "db:studio": "bun drizzle-kit studio",
    "db:generate": "bun drizzle-kit generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.4",
    "drizzle-kit": "^0.31.7",
    "prettier": "^3.7.4",
    "vitest": "^4.1.2",
    "vitest-mock-extended": "^3.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.1.0",
    "authenticator": "^1.1.5",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "expo-server-sdk": "^3.10.0",
    "express": "^5.1.0",
    "h3-js": "^4.4.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mailgen": "^2.0.32",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.0",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  }
}
