{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/mobile/emergency-tracking": [
        "../../packages/mobile/src/emergency-tracking/index.ts"
      ],
      "@repo/mobile/emergency-tracking/*": [
        "../../packages/mobile/src/emergency-tracking/*"
      ],
      "@repo/mobile/ui": ["../../packages/mobile/src/ui/index.ts"],
      "@repo/mobile/ui/*": ["../../packages/mobile/src/ui/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"],
  "exclude": ["node_modules"]
}
