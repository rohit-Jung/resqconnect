# Copy to `control-plane.env` and fill.

KHALTI_SECRET_KEY=replace_me
KHALTI_BASE_URL=https://dev.khalti.com/api/v2
KHALTI_RETURN_URL=http://localhost:7500/billing/callback
KHALTI_WEBSITE_URL=http://localhost:3001

# Admin auth (seeded on boot)
CONTROL_PLANE_ADMIN_EMAIL=admin@example.com
CONTROL_PLANE_ADMIN_PASSWORD=change_me_please
JWT_SECRET=change_me
JWT_EXPIRY=3600
